# Optional image upload settings for URL-based storage.
# If left empty, the app will save entries without image URL to avoid 413.

# Example (Cloudinary unsigned upload endpoint):
# VITE_IMAGE_UPLOAD_URL=https://api.cloudinary.com/v1_1/<cloud_name>/image/upload
# VITE_IMAGE_UPLOAD_PRESET=<unsigned_upload_preset>

VITE_IMAGE_UPLOAD_URL=
VITE_IMAGE_UPLOAD_PRESET=
